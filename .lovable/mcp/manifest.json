{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://nyieldwdhdzsglxovvuj.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "velomedos-mcp",
      "version": "0.1.0",
      "title": "VeloMed OS"
    },
    "tools": [
      {
        "name": "echo",
        "title": "Echo",
        "description": "Echo the input text back. Use to verify MCP connectivity.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "description": "Text to echo back."
            }
          },
          "required": [
            "text"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_services",
        "title": "List VeloMed OS services",
        "description": "Return the catalog of VeloMed OS product/service pages (slug, title, subtitle, audiences, outcomes, related). Public marketing content.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "description": "Optional keyword to filter services by title/subtitle/slug.",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_legal_documents",
        "title": "List published legal documents",
        "description": "List VeloMed OS published legal documents (privacy, terms, HIPAA, patient rights) with slug, locale, version and effective date.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "locale": {
              "description": "Optional locale filter (e.g. 'en', 'ar').",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_legal_document",
        "title": "Get a legal document",
        "description": "Fetch a published legal document by slug (and optional locale). Returns the rendered body (markdown/HTML) plus metadata.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Legal doc slug, e.g. 'privacy-home', 'terms-of-service', 'hipaa', 'patient-rights'."
            },
            "locale": {
              "description": "Optional locale (defaults to first published).",
              "type": "string"
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
